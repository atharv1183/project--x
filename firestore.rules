rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'admin', 'client_admin'];
    }

    function isManager() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isAdminLike() {
      return isAdmin() || isManager();
    }

    function isSuperAdmin() {
      return isSignedIn()
        && (
          request.auth.uid in ['EDTQPrn4WvPY3XvdgWNsPxo1Fnl2', 'aioJYnHqyZYDfQsiSXHJ3HjHEG53']
          || request.auth.token.role in ['super_admin', 'admin']
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'admin']
          )
        );
    }

    function isPlatformAdmin() {
      return isSuperAdmin();
    }

    function isPaymentOnlyPlatformClientUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'state',
        'paymentStatus',
        'billingCycle',
        'lastPaymentAmount',
        'lastPaymentAt',
        'subscriptionExpiryDate',
        'updatedAt'
      ]);
    }

    function requesterClientId() {
      let userClientId = exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId
        : '';
      return userClientId is string && userClientId.size() > 0
        ? userClientId
        : (
            exists(/databases/$(database)/documents/clientAdmins/$(request.auth.uid))
            && get(/databases/$(database)/documents/clientAdmins/$(request.auth.uid)).data.clientId is string
            && get(/databases/$(database)/documents/clientAdmins/$(request.auth.uid)).data.clientId.size() > 0
            ? get(/databases/$(database)/documents/clientAdmins/$(request.auth.uid)).data.clientId
            : ''
          );
    }

    function isPlatformClientOwner(clientId) {
      return clientId is string
        && clientId.size() > 0
        && exists(/databases/$(database)/documents/platformClients/$(clientId))
        && (
          get(/databases/$(database)/documents/platformClients/$(clientId)).data.adminUid == request.auth.uid
          || (
            get(/databases/$(database)/documents/platformClients/$(clientId)).data.adminEmail is string
            && get(/databases/$(database)/documents/platformClients/$(clientId)).data.adminEmail == request.auth.token.email
          )
        );
    }

    function canManageClientMembers(clientId) {
      return isSuperAdmin()
        || isPlatformClientOwner(clientId)
        || (isAdminLike() && requesterClientId() is string && clientId == requesterClientId());
    }

    function isSameClient(resourceData) {
      return resourceData.clientId is string && requesterClientId() is string && resourceData.clientId == requesterClientId();
    }

    function isUserInClient(userId, clientId) {
      return userId is string
        && clientId is string
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.clientId is string
        && get(/databases/$(database)/documents/users/$(userId)).data.clientId == clientId;
    }

    function isUserInRequesterClient(userId) {
      return isUserInClient(userId, requesterClientId());
    }
    
    function isSameClientBySubmitter(resourceData) {
      return resourceData.submitterId is string
        && requesterClientId() is string
        && exists(/databases/$(database)/documents/users/$(resourceData.submitterId))
        && get(/databases/$(database)/documents/users/$(resourceData.submitterId)).data.clientId is string
        && get(/databases/$(database)/documents/users/$(resourceData.submitterId)).data.clientId == requesterClientId();
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.assignedTo == request.auth.uid;
    }

    function canViewLead(resourceData) {
      return isSignedIn()
        && isSameClient(resourceData)
        && (
          resourceData.assignedTo == request.auth.uid
          || (resourceData.addedById is string && resourceData.addedById == request.auth.uid)
        );
    }

    function canAccessLead(resourceData) {
      return isSignedIn()
        && (
          (isAdminLike() && (isSuperAdmin() || isSameClient(resourceData)))
          || canViewLead(resourceData)
        );
    }

    // Validation helpers
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'role', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.role in ['super_admin', 'admin', 'client_admin', 'manager', 'employee', 'suspended', 'deleted']
        && data.createdAt is timestamp;
    }

    function isValidEmployeeInvite(data) {
      return data.keys().hasAll(['name', 'phone', 'role', 'codeHash', 'used', 'createdAt', 'createdBy'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.role == 'employee'
        && data.codeHash is string && data.codeHash.size() == 64
        && data.used is bool
        && data.createdAt is timestamp
        && data.createdBy is string;
    }

    function isValidEmployeeDirectory(data) {
      return data.keys().hasAll(['name', 'phone', 'role', 'clientId', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.role == 'employee'
        && data.clientId is string
        && data.updatedAt is timestamp;
    }

    function isInviteClaimUpdate() {
      return isSignedIn()
        && !resource.data.used
        && request.auth.token.email == resource.data.phone + '@estatepulse.com'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedAt', 'usedBy'])
        && request.resource.data.used == true
        && request.resource.data.usedAt is timestamp
        && request.resource.data.usedBy == request.auth.uid;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'phone', 'status', 'source', 'assignedTo', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.source is string && data.source.size() > 0 && data.source.size() <= 100
        && data.status in ['pending', 'interested', 'not_interested', 'deal_pending', 'deal_approved']
        && data.assignedTo is string
        && data.createdAt is timestamp;
    }

    function isValidFollowup(data) {
      return data.keys().hasAll(['date', 'remark', 'employeeId'])
        && data.keys().size() == 3
        && data.date is timestamp
        && data.remark is string && data.remark.size() > 0 && data.remark.size() <= 1000
        && data.employeeId == request.auth.uid;
    }

    function isValidRequirement(data) {
      return data.keys().hasAll(['name', 'phone', 'type', 'employeeId', 'employeeName', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.type is string && data.type.size() > 0 && data.type.size() <= 50
        && data.employeeId == request.auth.uid
        && data.createdAt is timestamp;
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['title', 'type', 'rate', 'location', 'status', 'submitterId', 'submitterName', 'createdAt', 'updatedAt', 'clientId'])
        && data.title is string && data.title.size() > 0
        && data.type is string && data.type.size() > 0
        && data.status in ['draft', 'pending_approval', 'approved', 'rejected']
        && data.submitterId == request.auth.uid
        && data.clientId is string
        && data.location is string && data.location.size() > 0;
    }

    function isValidAttendanceCorrection(data) {
      return data.keys().hasAll(['uid', 'employeeName', 'dateKey', 'date', 'requestedLoginTime', 'requestedLogoutTime', 'remark', 'status', 'requestedBy', 'requestedByName', 'requestedAt'])
        && data.uid == request.auth.uid
        && data.requestedBy == request.auth.uid
        && data.employeeName is string && data.employeeName.size() > 0 && data.employeeName.size() <= 100
        && data.dateKey is string && data.dateKey.size() == 10
        && data.date is timestamp
        && (data.requestedLoginTime == null || data.requestedLoginTime is timestamp)
        && (data.requestedLogoutTime == null || data.requestedLogoutTime is timestamp)
        && data.remark is string && data.remark.size() > 0 && data.remark.size() <= 1000
        && data.status == 'pending'
        && data.requestedByName is string && data.requestedByName.size() > 0 && data.requestedByName.size() <= 100
        && data.requestedAt is timestamp;
    }

    function isValidBroker(data) {
      return data.keys().hasAll(['name', 'phone', 'clientId', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15
        && data.clientId is string;
    }

    function isValidDemoRequest(data) {
      return data.keys().hasOnly(['name', 'email', 'phone', 'company', 'role', 'message', 'status', 'source', 'submittedAt', 'pagePath'])
        && data.keys().hasAll(['name', 'email', 'phone', 'status', 'source', 'submittedAt'])
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() > 3 && data.email.size() <= 255
        && data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20
        && data.company is string && data.company.size() <= 120
        && data.role is string && data.role.size() <= 80
        && data.message is string && data.message.size() <= 1000
        && data.status == 'new'
        && data.source == 'book-demo'
        && data.submittedAt is timestamp
        && data.pagePath is string && data.pagePath.size() <= 80;
    }

    // ---------------------------------------------------------
    // COLLECTIONS
    // ---------------------------------------------------------

    // Inventory
    match /inventory/{itemId} {
      allow list: if isSuperAdmin() || (
        isSignedIn()
        && (isSameClient(resource.data) || isSameClientBySubmitter(resource.data))
        && (
          isAdminLike()
          || resource.data.status == 'approved'
          || resource.data.submitterId == request.auth.uid
        )
      ) || (isSignedIn() && resource.data.visibilityScope == 'all' && resource.data.status == 'approved');
      allow get: if isSuperAdmin() || (isSignedIn() && (isSameClient(resource.data) || isSameClientBySubmitter(resource.data))) || (isSignedIn() && resource.data.status == 'approved');
      allow create: if isSignedIn()
        && isValidInventory(request.resource.data)
        && (
          (isSuperAdmin() && request.resource.data.clientId is string)
          || (
            request.resource.data.clientId is string
            && request.resource.data.clientId == requesterClientId()
            && (
              (isAdminLike() && request.resource.data.status in ['approved', 'pending_approval', 'draft'])
              || (!isAdminLike() && request.resource.data.status in ['pending_approval', 'draft'])
            )
          )
        );
      allow update: if isSignedIn() && (
        (isSuperAdmin() || ((isSameClient(resource.data) || isSameClientBySubmitter(resource.data)) && (
          isAdminLike() ||
          (resource.data.submitterId == request.auth.uid && (resource.data.status == 'draft' || resource.data.status == 'rejected' || resource.data.status == 'pending_approval'))
        )))
      );
      allow delete: if false;
    }

    // Admin-only broker directory
    match /brokers/{brokerId} {
      allow read: if isSuperAdmin() || (isAdminLike() && isSameClient(resource.data));
      allow create, update: if (isSuperAdmin() || (isAdminLike() && request.resource.data.clientId == requesterClientId())) && isValidBroker(request.resource.data);
      allow delete: if isSuperAdmin() || (isAdminLike() && isSameClient(resource.data));
    }

    // Requirements
    match /requirements/{reqId} {
      allow list: if isSignedIn() && (
        resource.data.employeeId == request.auth.uid ||
        (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)))
      );
      allow get: if isSignedIn() && ((isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && isValidRequirement(request.resource.data)
        && (isSuperAdmin() || (request.resource.data.clientId is string && request.resource.data.clientId == requesterClientId()));
      allow update: if isSignedIn() && ((isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || resource.data.employeeId == request.auth.uid);
      allow delete: if isSignedIn() && ((isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || resource.data.employeeId == request.auth.uid);
    }

    // Employee invites
    match /employeeInvites/{phone} {
      allow get: if isAdminLike() || (isSignedIn() && request.auth.token.email == phone + '@estatepulse.com');
      allow list: if isAdminLike();
      allow create: if isAdminLike() && isValidEmployeeInvite(request.resource.data);
      allow update: if (isAdminLike() && isValidEmployeeInvite(request.resource.data)) || isInviteClaimUpdate();
      allow delete: if isAdminLike();
    }

    // Employee directory with only non-sensitive fields
    match /employeeDirectory/{userId} {
      allow get, list: if isSuperAdmin() || (isSignedIn() && isSameClient(resource.data));
      allow create: if isValidEmployeeDirectory(request.resource.data)
        && request.resource.data.clientId is string
        && (
          canManageClientMembers(request.resource.data.clientId)
          || (
            request.auth.uid == userId
            && request.resource.data.clientId == requesterClientId()
            && request.resource.data.phone + '@estatepulse.com' == request.auth.token.email
          )
        );
      allow update: if (isSuperAdmin() || (isAdminLike() && isSameClient(resource.data))) && isValidEmployeeDirectory(request.resource.data);
      allow delete: if isSuperAdmin() || (isAdminLike() && isSameClient(resource.data));
    }

    // Maps client_admin auth uid -> tenant clientId when users.clientId is missing.
    match /clientAdmins/{uid} {
      allow get: if request.auth.uid == uid || isSuperAdmin();
      allow list: if false;
      allow create, update: if isSuperAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.clientId is string
          && request.resource.data.clientId.size() > 0
          && request.resource.data.keys().hasOnly(['clientId'])
          && exists(/databases/$(database)/documents/platformClients/$(request.resource.data.clientId))
          && (
            get(/databases/$(database)/documents/platformClients/$(request.resource.data.clientId)).data.adminUid == request.auth.uid
            || (
              get(/databases/$(database)/documents/platformClients/$(request.resource.data.clientId)).data.adminEmail is string
              && get(/databases/$(database)/documents/platformClients/$(request.resource.data.clientId)).data.adminEmail == request.auth.token.email
            )
          )
        );
      allow delete: if isSuperAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || request.auth.uid == userId;
      allow list: if isSuperAdmin() || (isAdminLike() && requesterClientId() is string && resource.data.clientId == requesterClientId());
      allow create: if isSignedIn()
        && isValidUser(request.resource.data)
        && (
          (request.resource.data.clientId is string && canManageClientMembers(request.resource.data.clientId))
          || (
            request.auth.uid == userId
            && request.resource.data.role == 'employee'
            && request.resource.data.email == request.auth.token.email
            && request.resource.data.phone + '@estatepulse.com' == request.auth.token.email
          )
        );
      allow update: if (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)))
        || (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name',
            'phone',
            'email',
            'profileImageUrl',
            'brandLogoUrl',
            'brandCompanyName',
            'brandTagline',
            'updatedAt'
          ])
        )
        || (
          request.auth.uid == userId
          && resource.data.role == 'client_admin'
          && (!(resource.data.clientId is string) || resource.data.clientId == '')
          && request.resource.data.clientId is string
          && request.resource.data.clientId.size() > 0
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientId', 'clientName', 'updatedAt'])
          && isPlatformClientOwner(request.resource.data.clientId)
        );
      allow delete: if (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || (isSignedIn() && resource.data.phone + "@estatepulse.com" == request.auth.token.email);
    }

    // Leads
    match /leads/{leadId} {
      allow get: if canAccessLead(resource.data);
      allow list: if canAccessLead(resource.data);
      allow create: if isValidLead(request.resource.data) && (
        (isAdminLike()
          && (
            isSuperAdmin()
            || (
              request.resource.data.clientId is string
              && request.resource.data.clientId == requesterClientId()
              && isUserInRequesterClient(request.resource.data.assignedTo)
            )
          )
        ) ||
        (
          request.resource.data.clientId is string
          && request.resource.data.clientId == requesterClientId()
          && isUserInRequesterClient(request.resource.data.assignedTo)
          &&
          request.resource.data.assignedTo == request.auth.uid
          && request.resource.data.source == 'Employee Added'
          && request.resource.data.addedById == request.auth.uid
          && request.resource.data.addedByName is string
          && request.resource.data.addedByName.size() > 0
          && request.resource.data.addedByRole == 'employee'
        )
      );
      allow update: if request.resource.data.clientId == resource.data.clientId
        && (isSuperAdmin() || isUserInClient(request.resource.data.assignedTo, resource.data.clientId))
        && (((isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) || (isOwner(resource.data) && isSameClient(resource.data)))) && (
        // Admin/manager can update lead payloads used by dashboard workflows.
        (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data))) ||
        // Employee can update status, follow-up info, and transfer lead
        (isOwner(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'status', 'nextFollowupAt', 'lastRemark', 'siteVisitPhoto', 'siteVisitLocation', 'siteVisitAt', 'assignedTo', 'hasFollowupTime', 'nextFollowupTime', 'deletedAt', 'deletedBy', 'deletedByName', 'updatedAt'])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt', 'phone'])
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['name'])
            || (request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100))
        )
      );
      allow delete: if isSignedIn()
        && (isSuperAdmin() || (isSameClient(resource.data) && (isAdminLike() || isOwner(resource.data))));
    }

    // Deleted Leads Collection
    match /deletedLeads/{leadId} {
      allow read, delete: if isSignedIn() && (isSuperAdmin() || isSameClient(resource.data));
      allow create: if isSignedIn() && (isSuperAdmin() || isSameClient(request.resource.data));
      allow update: if isSignedIn() && (isSuperAdmin() || (isSameClient(resource.data) && isSameClient(request.resource.data)));
    }

    // Followups
    match /leads/{leadId}/followups/{followupId} {
      allow read: if canAccessLead(get(/databases/$(database)/documents/leads/$(leadId)).data);
      allow create: if canAccessLead(get(/databases/$(database)/documents/leads/$(leadId)).data) && isValidFollowup(request.resource.data);
    }

    // System allocation
    match /system/{docId} {
      allow read: if isSuperAdmin() || (isAdminLike() && requesterClientId() is string && docId == 'allocation_' + requesterClientId());
      allow write: if isSuperAdmin() || (isAdminLike() && requesterClientId() is string && docId == 'allocation_' + requesterClientId());
    }

    // Platform control plane collections (super admin only)
    match /platformFeatureToggles/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformAnnouncements/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /platformConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /platformEmailTemplates/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformClients/{clientId} {
      allow read: if isPlatformAdmin()
        || (isSignedIn() && requesterClientId() is string && requesterClientId() == clientId)
        || (isSignedIn() && resource.data.adminUid is string && resource.data.adminUid == request.auth.uid)
        || (isSignedIn() && resource.data.adminEmail is string && resource.data.adminEmail == request.auth.token.email);
      allow create, delete: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || (isSignedIn() && isPaymentOnlyPlatformClientUpdate());

      match /internalNotes/{docId} {
        allow read, write: if isPlatformAdmin();
      }
    }

    match /clientBranding/{clientId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create, update: if isSuperAdmin()
        || (
          isAdmin()
          && requesterClientId() is string
          && requesterClientId() == clientId
          && request.resource.data.keys().hasOnly(['logoUrl', 'companyName', 'tagline', 'updatedAt', 'updatedBy'])
          && request.resource.data.logoUrl is string
          && request.resource.data.companyName is string
          && request.resource.data.tagline is string
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == request.auth.uid
        );
      allow delete: if isSuperAdmin();
    }

    match /platformApiKeys/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformDataExportJobs/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformQueueJobs/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformVersionHistory/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /platformFollowupReminders/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /paymentTransactions/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isPlatformAdmin() || isAdmin();
      allow delete: if isPlatformAdmin();
    }

    match /demoRequests/{docId} {
      allow create: if isValidDemoRequest(request.resource.data)
        && request.resource.data.submittedAt == request.time
        && request.resource.data.keys().size() <= 10;
      allow read: if isSuperAdmin();
      allow update: if isSuperAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy'])
        && request.resource.data.status in ['new', 'contacted', 'closed']
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /inventoryBackups/{docId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isSameClient(resource.data));
      allow create: if isSignedIn()
        && request.resource.data.clientId is string
        && (isSuperAdmin() || request.resource.data.clientId == requesterClientId());
      allow update, delete: if false;
    }

    match /sessionRevocations/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /auditLogs/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.actorId == request.auth.uid
        && (
          isSuperAdmin()
          || request.resource.data.clientId == requesterClientId()
        );
      allow read: if isSuperAdmin()
        || (
          isSignedIn()
          && (
            resource.data.actorId == request.auth.uid
            || (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'client_admin']
              && resource.data.clientId == requesterClientId()
            )
          )
        );
      allow update, delete: if false;
    }

    // Attendance
    match /attendance/{recordId} {
      allow list: if (isSignedIn() && resource.data.uid == request.auth.uid) || (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid 
        && request.resource.data.keys().hasAll(['uid', 'employeeName', 'timestamp', 'type', 'location'])
        && (isSuperAdmin() || (request.resource.data.clientId is string && request.resource.data.clientId == requesterClientId()))
        && request.resource.data.timestamp == request.time;
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)));
    }

    // Attendance correction requests
    match /attendanceCorrections/{requestId} {
      allow list: if (isSignedIn() && resource.data.uid == request.auth.uid) || (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)));
      allow get: if (isSignedIn() && resource.data.uid == request.auth.uid) || (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)));
      allow create: if isSignedIn() && isValidAttendanceCorrection(request.resource.data)
        && (isSuperAdmin() || (request.resource.data.clientId is string && request.resource.data.clientId == requesterClientId()));
      allow update: if (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'reviewRemark'])
        && request.resource.data.status in ['approved', 'rejected'];
      allow delete: if isAdminLike() && (isSuperAdmin() || isSameClient(resource.data));
    }

    // Notifications
    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdminLike();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Lead transfer register
    match /leadTransfers/{transferId} {
      allow read: if isSignedIn()
        && (
          (isAdminLike() && (isSuperAdmin() || isSameClient(resource.data)))
          || (isSameClient(resource.data) && (
            resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid
            || resource.data.transferredByUid == request.auth.uid
          ))
        );
      allow create: if (
        isAdminLike()
        && (
          isSuperAdmin()
          || (
            request.resource.data.clientId is string
            && request.resource.data.clientId == requesterClientId()
            && isUserInRequesterClient(request.resource.data.fromUid)
            && isUserInRequesterClient(request.resource.data.toUid)
          )
        )
      ) || (
        isSignedIn()
        && request.resource.data.clientId is string
        && request.resource.data.clientId == requesterClientId()
        && isUserInRequesterClient(request.resource.data.fromUid)
        && isUserInRequesterClient(request.resource.data.toUid)
        && request.resource.data.transferredByUid == request.auth.uid
      );
      allow update, delete: if isAdminLike() && (isSuperAdmin() || isSameClient(resource.data));
    }

    // Per-owner notification preferences
    match /notificationSettings/{ownerId} {
      allow get, list: if isSignedIn() && (isAdminLike() || request.auth.uid == ownerId);
      allow create, update: if isSignedIn() && (isAdminLike() || request.auth.uid == ownerId);
      allow delete: if isAdminLike();
    }

    // Support tickets
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isAdminLike() && (
          isSuperAdmin() ||
          (resource.data.companyId is string && requesterClientId() is string && resource.data.companyId == requesterClientId()) ||
          (resource.data.clientId is string && requesterClientId() is string && resource.data.clientId == requesterClientId())
        ))
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'title', 'message', 'status', 'createdAt']);
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isAdminLike() && (
          isSuperAdmin() ||
          (resource.data.companyId is string && requesterClientId() is string && resource.data.companyId == requesterClientId()) ||
          (resource.data.clientId is string && requesterClientId() is string && resource.data.clientId == requesterClientId())
        ))
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isAdminLike() && (
          isSuperAdmin() ||
          (resource.data.companyId is string && requesterClientId() is string && resource.data.companyId == requesterClientId()) ||
          (resource.data.clientId is string && requesterClientId() is string && resource.data.clientId == requesterClientId())
        ))
      );
    }
  }
}
